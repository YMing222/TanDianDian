page {
  min-height: 100%;
  background: #fffdf5;
  color: #27231f;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #eee3cf;
  border-radius: 8rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(44, 36, 24, 0.06);
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.muted {
  color: #7c7062;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #fff3bf;
  color: #92400e;
  font-size: 22rpx;
}

.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 8rpx;
  background: #f59e0b;
  color: #ffffff;
  font-weight: 700;
}

.ghost-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e7d6b8;
  background: #ffffff;
  color: #3f3529;
}

<view class="page home">
  <view class="hero">
    <view>
      <view class="eyebrow">今日出摊</view>
      <view class="title">找得到，也约得到</view>
      <view class="subtitle">附近小吃摊位、菜单和预约自取</view>
    </view>
    <button class="locate" bindtap="getLocation">定位</button>
  </view>

  <view class="section-title">附近摊位</view>
  <block wx:for="{{vendors}}" wx:key="_id">
    <view class="card vendor-card" bindtap="openVendor" data-id="{{item._id}}">
      <view class="row between">
        <view class="vendor-name">{{item.name}}</view>
        <view class="tag">{{item.statusText}}</view>
      </view>
      <view class="muted desc">{{item.category}} · {{item.distanceText}}</view>
      <view class="location">{{item.locationText}}</view>
      <view class="muted">营业时间：{{item.businessHours}}</view>
    </view>
  </block>
</view>

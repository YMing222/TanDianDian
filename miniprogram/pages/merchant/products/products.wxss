.form-card {
  margin-top: 18rpx;
}

.form-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.field {
  margin-top: 18rpx;
}

.label {
  margin-bottom: 8rpx;
  color: #3f3529;
  font-size: 26rpx;
  font-weight: 700;
}

input,
textarea {
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid #e7d6b8;
  border-radius: 8rpx;
  background: #fffdf5;
  font-size: 28rpx;
}

input {
  height: 76rpx;
  padding: 0 20rpx;
}

textarea {
  min-height: 132rpx;
  padding: 18rpx 20rpx;
}

.two-column {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0e3cf;
}

.switch-row .muted {
  font-size: 24rpx;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.flavor-section {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #f0e3cf;
}

.section-title {
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.compact {
  padding: 18rpx 0;
}

.flavor-presets,
.selected-flavors {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.flavor-presets button {
  margin: 0;
}

.custom-row {
  display: grid;
  grid-template-columns: 1fr 144rpx;
  gap: 14rpx;
  margin-top: 18rpx;
}

.add-btn {
  height: 76rpx;
  line-height: 76rpx;
}

.flavor-tag {
  padding: 10rpx 18rpx;
  border-radius: 8rpx;
  background: #fff3bf;
  color: #92400e;
  font-size: 24rpx;
}

.empty-flavor {
  margin-top: 18rpx;
}

.save-btn {
  margin: 0;
}

.empty {
  padding: 56rpx 20rpx;
  color: #7c7062;
  text-align: center;
}

.product {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.name {
  max-width: 360rpx;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.5;
}

.meta {
  margin-top: 12rpx;
  color: #92400e;
  font-size: 26rpx;
  font-weight: 700;
}

.flavor-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.ops {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  gap: 10rpx;
}

.ops button {
  min-width: 144rpx;
}

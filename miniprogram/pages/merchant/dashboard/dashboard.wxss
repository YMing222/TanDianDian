.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 20rpx 0 30rpx;
}

.action {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.location {
  margin-top: 10rpx;
  font-size: 30rpx;
}

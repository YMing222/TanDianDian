.section-title {
  margin: 12rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.field {
  margin-bottom: 24rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  margin-bottom: 10rpx;
  color: #6b6256;
  font-size: 26rpx;
}

input,
textarea,
.picker {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #fffaf0;
}

textarea {
  min-height: 140rpx;
}

.item {
  margin-bottom: 16rpx;
}

.item-main {
  width: 100%;
}

.item-name {
  font-weight: 700;
}

.empty {
  padding: 48rpx 20rpx;
  color: #7c7062;
  text-align: center;
}

.qty {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty button {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  padding: 0;
}

.flavors {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f0e3cf;
}

.flavor-title {
  color: #3f3529;
  font-size: 26rpx;
  font-weight: 700;
}

.flavor-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.flavor-options button {
  margin: 0;
}

.selected-text {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.summary {
  position: sticky;
  bottom: 0;
  margin-top: 24rpx;
  padding: 18rpx 0;
  background: #fffdf5;
  font-weight: 800;
}

.submit {
  width: 240rpx;
}

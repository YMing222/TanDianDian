<view class="page">
  <view class="section-title">预约信息</view>
  <view class="card form">
    <view class="field">
      <view class="label">自取时间</view>
      <picker mode="time" value="{{pickupTime}}" bindchange="onPickupTimeChange">
        <view class="picker">{{pickupTime || '请选择时间'}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">联系电话</view>
      <input type="number" value="{{contactPhone}}" placeholder="用于摊主联系你" bindinput="onPhoneInput" />
    </view>
    <view class="field">
      <view class="label">备注</view>
      <textarea value="{{remark}}" placeholder="口味、忌口或其他说明" bindinput="onRemarkInput" />
    </view>
  </view>

  <view class="section-title">选择商品</view>
  <view wx:if="{{!items.length}}" class="empty">当前没有可预约商品</view>
  <block wx:for="{{items}}" wx:key="_id">
    <view class="card item">
      <view>
        <view class="item-name">{{item.name}}</view>
        <view class="muted">￥{{item.priceText}}</view>
      </view>
      <view class="qty">
        <button data-id="{{item._id}}" bindtap="minus">-</button>
        <text>{{item.quantity}}</text>
        <button data-id="{{item._id}}" bindtap="plus">+</button>
      </view>
    </view>
  </block>

  <view class="summary row between">
    <view>合计：￥{{totalAmount}}</view>
    <button class="primary-btn submit" loading="{{isSubmitting}}" bindtap="submitOrder">提交预约</button>
  </view>
</view>

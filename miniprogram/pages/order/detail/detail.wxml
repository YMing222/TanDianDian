<view class="page">
  <view wx:if="{{order}}" class="card header-card">
    <view class="row between">
      <view class="vendor">{{order.vendorName}}</view>
      <view class="tag">{{order.statusText}}</view>
    </view>
    <view class="muted">支付状态：{{order.paymentStatusText}}</view>
    <view class="muted">自取时间：{{order.pickupTime}}</view>
    <view class="muted">联系电话：{{order.contactPhone}}</view>
    <view wx:if="{{order.remark}}" class="muted">备注：{{order.remark}}</view>
  </view>

  <view wx:if="{{order}}" class="section-title">商品明细</view>
  <block wx:for="{{items}}" wx:key="_id">
    <view class="card item">
      <view>
        <view class="item-name">{{item.name}}</view>
        <view wx:if="{{item.flavorText}}" class="muted">口味：{{item.flavorText}}</view>
        <view class="muted">单价：￥{{item.priceText}} · 数量：{{item.quantity}}</view>
      </view>
      <view class="subtotal">￥{{item.subtotalText}}</view>
    </view>
  </block>

  <view wx:if="{{order}}" class="card total-card">
    <view class="row between">
      <view>合计</view>
      <view class="total">￥{{order.totalText}}</view>
    </view>
  </view>

  <view wx:if="{{order && (order.canPay || order.canCancel)}}" class="detail-actions">
    <button wx:if="{{order.canPay}}" class="primary-btn" loading="{{isPaying}}" bindtap="payAgain">重新支付</button>
    <button wx:if="{{order.canCancel}}" class="ghost-btn" loading="{{isCanceling}}" bindtap="cancelOrder">取消订单</button>
  </view>
</view>

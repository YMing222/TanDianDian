.cover {
  min-height: 220rpx;
  padding: 36rpx 28rpx;
  border-radius: 8rpx;
  background: #2f2a23;
  color: #fffaf0;
}

.cover-title {
  font-size: 46rpx;
  font-weight: 800;
}

.cover-subtitle {
  margin-top: 12rpx;
  color: #f7c948;
}

.info {
  margin-top: 20rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 800;
}

.notice {
  margin: 20rpx 0;
  padding: 18rpx;
  background: #fff8db;
  border-radius: 8rpx;
}

.stall-photo {
  width: 100%;
  height: 320rpx;
  margin-top: 20rpx;
  border-radius: 8rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.section-title {
  margin: 32rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.product {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
}

.price {
  color: #dc2626;
  font-weight: 800;
}

.order-btn {
  margin-top: 28rpx;
}

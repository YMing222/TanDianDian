<view class="page">
  <view class="cover">
    <view class="cover-title">{{vendor.name}}</view>
    <view class="cover-subtitle">{{vendor.category}}</view>
  </view>

  <view class="card info">
    <view class="row between">
      <view class="name">{{vendor.name}}</view>
      <view class="tag">{{vendor.isOpen ? '营业中' : '未出摊'}}</view>
    </view>
    <view class="notice">{{vendor.announcement}}</view>
    <view class="muted">位置：{{vendor.locationText}}</view>
    <view class="muted">时间：{{vendor.businessHours}}</view>
    <image wx:if="{{vendor.locationPhotoUrl || vendor.locationPhotoFileID}}" class="stall-photo" src="{{vendor.locationPhotoUrl || vendor.locationPhotoFileID}}" mode="aspectFill" bindtap="previewLocationPhoto" />
    <view class="actions">
      <button class="ghost-btn" bindtap="openMap">导航</button>
      <button class="ghost-btn" bindtap="callVendor">联系</button>
    </view>
  </view>

  <view class="section-title">菜单</view>
  <block wx:for="{{products}}" wx:key="_id">
    <view class="card product">
      <view>
        <view class="product-name">{{item.name}}</view>
        <view class="muted">{{item.description}}</view>
      </view>
      <view class="price">￥{{item.price}}</view>
    </view>
  </block>

  <button class="primary-btn order-btn" bindtap="createOrder">预约点单</button>
</view>
